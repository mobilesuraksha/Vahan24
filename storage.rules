rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Bookings - users can upload their own vehicle photos
    match /bookings/{userId}/{allPaths=**} {
      allow read, write: if request.auth.uid == userId && 
                            isValidImage() &&
                            request.resource.size < 5 * 1024 * 1024; // 5MB max
    }

    // Mechanic profiles - mechanics can upload their own documents
    match /mechanics/{mechanicId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == mechanicId && 
                      request.resource.size < 10 * 1024 * 1024; // 10MB max
    }

    // Public images - read access for all
    match /public/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // Helper function - validate image files
    function isValidImage() {
      return request.resource.contentType.matches('image/.*');
    }

    // Helper function - check if user is admin
    function isAdmin() {
      return request.auth.token.email in ['admin@gmail.com', 'youradmin@email.com'];
    }
  }
}
